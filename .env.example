# TRADING SYSTEM — ENVIRONMENT VARIABLES
# 
# Instructions:
# 1. Copy this file: cp .env.example .env
# 2. Fill in your actual API keys below
# 3. NEVER commit .env to git (protected by .gitignore)
# 4. NEVER share .env with anyone

# ============================================================
# METATRADER 5 CREDENTIALS
# ============================================================
# Get from your Exness account:
# 1. Log in to https://exness.com
# 2. Go to Personal Area → MT5 Accounts
# 3. Copy Login (account number), Password, Server name
#
# Example server: Exness-MT5-Demo (for demo) or Exness-MT5 (live)

MT5_LOGIN=123456789
MT5_PASSWORD=your_password_here
MT5_SERVER=Exness-MT5-Demo

# ============================================================
# ANTHROPIC API KEY (Claude)
# ============================================================
# Get API key:
# 1. Go to https://console.anthropic.com/account/keys
# 2. Click "Create Key"
# 3. Copy the key (starts with sk-ant-)
#
# Format: sk-ant-xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
# Cost: ~$0.004 per signal after pre-filter rejection

ANTHROPIC_API_KEY=sk-ant-

# ============================================================
# TELEGRAM BOT TOKEN
# ============================================================
# Create bot:
# 1. Open Telegram and search for @BotFather
# 2. Send: /newbot
# 3. Choose name (e.g., "MyTradingBot")
# 4. Choose username (e.g., @MyTradingBot_01)
# 5. Copy the token (123456789:ABCdef_GHijKL-MNopQrStUVwXyZ)
#
# Format: 123456789:ABCdef_GHijKL-MNopQrStUVwXyZ

TELEGRAM_BOT_TOKEN=

# ============================================================
# TELEGRAM CHAT ID
# ============================================================
# Get your chat ID:
# 1. Message your new bot anything (e.g., "test")
# 2. Replace TOKEN below and visit this URL in browser:
#    https://api.telegram.org/bot<TOKEN>/getUpdates
# 3. Look for the JSON response, find: "chat": { "id": YOUR_ID }
# 4. Copy that ID number here
#
# Example: 123456789 (just the number, no quotes)

TELEGRAM_CHAT_ID=

# ============================================================
# OPTIONAL: TRADING PARAMETER OVERRIDES
# ============================================================
# Leave these commented to use defaults from config.py
# Only uncomment if you want to change system behavior

# Risk per trade as decimal (default: 0.01 = 1%)
# RISK_PER_TRADE=0.01

# Minimum Claude confidence percentage (default: 68%)
# MIN_CLAUDE_CONFIDENCE=68

# Minimum pre-filter score out of 9 (default: 7)
# MIN_PREFILTER_SCORE=7

# ============================================================
# NOTES
# ============================================================
# - All fields are required except optional ones above
# - If .env is missing, system will fail with error message
# - Change MT5_SERVER to "Exness-MT5" for live account
# - Do NOT use demo account credentials on live or vice versa
# - API keys will be checked on system startup
